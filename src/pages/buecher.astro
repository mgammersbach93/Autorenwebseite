---
import Layout from '../layouts/Layout.astro';

const books = [
	{
		title: 'Buch 1',
		subtitle: 'Untertitel oder Jahr',
		description:
			'Kurze Beschreibung des Buches – worum geht es, welchen Mehrwert bietet es dem Leser? Persönliche Entwicklung und Lesen gehen hier Hand in Hand.',
		cover: null,
		slug: '#',
		cta: 'Mehr erfahren',
	},
	{
		title: 'Buch 2',
		subtitle: 'Untertitel oder Jahr',
		description:
			'Eine weitere inspirierende Geschichte aus dem Alltag, die zu persönlichem Wachstum verhelfen kann. Hier kannst du den Klappentext ergänzen.',
		cover: null,
		slug: '#',
		cta: 'Mehr erfahren',
	},
];
---

<Layout title="Meine Bücher">
	<!-- Full viewport Smaragd header -->
	<section class="buecher-hero">
		<div class="buecher-hero-inner">
			<h1 class="buecher-hero-title">Meine Bücher</h1>
			<p class="buecher-hero-intro">
				Lesen und persönliche Entwicklung – das geht bei meinen Büchern Hand in Hand. Tauche ein in
				inspirierende Geschichten aus dem Alltag, die dir zu persönlichem Wachstum verhelfen.
			</p>
		</div>
	</section>

	<!-- Book list: max-width 1300px centered -->
	<section class="buecher-list">
		<div class="container buecher-list-inner">
			<div class="book-grid">
				{books.map((book) => (
					<article class="book-card">
						<a href={book.slug} class="book-cover-wrap">
							{book.cover ? (
								<img src={book.cover} alt="" class="book-cover-img" />
							) : (
								<div class="book-cover-placeholder" aria-hidden="true"></div>
							)}
						</a>
						<div class="book-card-body">
							<h2 class="book-title">{book.title}</h2>
							{book.subtitle && <p class="book-subtitle">{book.subtitle}</p>}
							<p class="book-description">{book.description}</p>
							<a href={book.slug} class="btn btn-primary book-cta">
								{book.cta}
							</a>
						</div>
					</article>
				))}
			</div>
		</div>
	</section>
</Layout>

<style>
	/* Buttons – same as home */
	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: auto;
		padding: 0.85rem 2rem;
		font-family: 'Manrope', sans-serif;
		font-size: 11px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.16em;
		border-radius: 0;
		cursor: pointer;
		transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
		text-decoration: none;
		white-space: nowrap;
		box-sizing: border-box;
	}

	.btn-primary {
		background-color: var(--emerald);
		color: var(--bg);
		border: none;
	}

	.btn-primary:hover {
		background-color: #243d35;
	}

	/* Full viewport Smaragd header */
	.buecher-hero {
		width: 100vw;
		margin-left: calc(50% - 50vw);
		background-color: var(--emerald);
		color: var(--bg);
		padding-block: 5rem;
		padding-inline: 2rem;
		box-sizing: border-box;
		margin-bottom: 0;
	}

	@media (min-width: 961px) {
		.buecher-hero {
			padding-inline: var(--page-padding-desktop);
			padding-block: 6rem;
		}
	}

	.buecher-hero-inner {
		max-width: 1300px;
		margin-inline: auto;
		max-width: 42rem;
	}

	.buecher-hero-title {
		font-family: 'Manrope', sans-serif;
		font-size: clamp(2rem, 3vw, 2.6rem);
		font-weight: 700;
		letter-spacing: -0.03em;
		margin: 0 0 var(--space-3);
		color: var(--bg);
	}

	.buecher-hero-intro {
		font-family: 'Manrope', sans-serif;
		font-size: 16px;
		font-weight: 300;
		line-height: 1.7;
		margin: 0;
		color: var(--bg);
		opacity: 0.9;
	}

	/* Book list section */
	.buecher-list {
		background-color: var(--bg);
		padding-block: 5rem 6rem;
	}

	.buecher-list-inner {
		/* container already has max-width 1300px */
	}

	.book-grid {
		display: grid;
		gap: var(--space-6);
	}

	@media (min-width: 961px) {
		.book-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 4rem var(--space-6);
		}
	}

	.book-card {
		display: grid;
		gap: var(--space-4);
		grid-template-columns: 1fr;
		align-items: start;
	}

	@media (min-width: 720px) {
		.book-card {
			grid-template-columns: 200px 1fr;
			gap: var(--space-5);
		}
	}

	@media (min-width: 961px) {
		.book-card {
			grid-template-columns: 220px 1fr;
		}
	}

	.book-cover-wrap {
		display: block;
		text-decoration: none;
		color: inherit;
		transition: opacity 0.2s ease;
	}

	.book-cover-wrap:hover {
		opacity: 0.9;
	}

	.book-cover-placeholder,
	.book-cover-img {
		width: 100%;
		aspect-ratio: 2 / 3;
		background-color: var(--muted);
		opacity: 0.35;
		object-fit: cover;
	}

	.book-cover-img {
		opacity: 1;
	}

	.book-card-body {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}

	.book-title {
		font-family: 'Manrope', sans-serif;
		font-size: clamp(1.35rem, 2vw, 1.6rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin: 0;
		color: var(--text);
	}

	.book-subtitle {
		font-family: 'Manrope', sans-serif;
		font-size: 13px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--muted);
		margin: 0;
	}

	.book-description {
		font-family: 'Manrope', sans-serif;
		font-size: 16px;
		font-weight: 300;
		line-height: 1.7;
		margin: 0;
		color: var(--muted);
		flex: 1;
	}

	.book-cta {
		width: fit-content;
		margin-top: var(--space-2);
	}

	@media (max-width: 960px) {
		.buecher-hero {
			padding-inline: 2rem;
		}
	}

	@media (max-width: 720px) {
		.buecher-list {
			padding-block: 3rem 4rem;
		}

		.book-card {
			grid-template-columns: 1fr;
			text-align: center;
		}

		.book-cover-wrap {
			max-width: 180px;
			margin-inline: auto;
		}

		.book-cta {
			margin-inline: auto;
		}
	}
</style>
